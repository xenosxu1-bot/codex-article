# Repository text normalization
/.gitattributes text eol=lf
# Keep Markdown/docs/scripts stable on GitHub and Windows editors.
*.md text eol=lf
*.py text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Keep common workflow files normalized as well.
*.ps1 text eol=lf
*.csv text eol=lf

# Image assets must never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
# Preserve immutable external-source snapshots byte-for-byte and skip whitespace lint.
10-外部原文归档/**/source.html -text -whitespace
